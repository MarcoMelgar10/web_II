<%- include('../partials/header') %>

<h2>Dejar Reseña</h2>

<% if (reserva.horario && reserva.horario.cancha) { %>
  <p>Cancha: <b><%= reserva.horario.cancha.nombre %></b></p>
  <p>Fecha: <%= reserva.horario.fecha %> | Hora: <%= reserva.horario.hora_inicio %> - <%= reserva.horario.hora_fin %></p>
<% } %>

<div class="card" style="max-width: 450px;">
  <form action="/resenas" method="POST">
    <input type="hidden" name="reserva_id" value="<%= reserva.id %>">
    <div class="form-group">
      <label>Calificación (1-5)</label>
      <select name="calificacion" required>
        <option value="">Seleccionar</option>
        <option value="1">1</option>
        <option value="2">2</option>
        <option value="3">3</option>
        <option value="4">4</option>
        <option value="5">5</option>
      </select>
    </div>
    <div class="form-group">
      <label for="comentario">Comentario (opcional)</label>
      <textarea id="comentario" name="comentario" rows="3"></textarea>
    </div>
    <button type="submit" class="btn">Enviar</button>
    <a href="/reservas/mis-reservas" class="btn btn-secondary">Cancelar</a>
  </form>
</div>

<%- include('../partials/footer') %>
