<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Canchas Deportivas' %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Arial, sans-serif; font-size: 14px; background: #f5f5f5; }
    nav { background: #333; padding: 10px 20px; display: flex; justify-content: space-between; align-items: center; }
    nav a { color: #fff; text-decoration: none; margin-right: 15px; }
    nav a:hover { text-decoration: underline; }
    .nav-right { display: flex; align-items: center; gap: 10px; }
    .nav-right span { color: #ccc; font-size: 13px; }
    .container { max-width: 960px; margin: 20px auto; padding: 0 15px; }
    table { width: 100%; border-collapse: collapse; margin: 10px 0; }
    table th, table td { border: 1px solid #ccc; padding: 8px; text-align: left; }
    table th { background: #333; color: #fff; }
    tr:hover { background: #eee; }
    .btn { display: inline-block; padding: 5px 12px; text-decoration: none; border: 1px solid #333; background: #333; color: #fff; cursor: pointer; font-size: 13px; }
    .btn:hover { background: #555; }
    .btn-danger { background: #c00; border-color: #c00; }
    .btn-danger:hover { background: #a00; }
    .btn-warning { background: #e90; border-color: #e90; }
    .btn-warning:hover { background: #c70; }
    .btn-success { background: #090; border-color: #090; color: #fff; }
    .btn-success:hover { background: #070; }
    .btn-secondary { background: #888; border-color: #888; }
    .btn-secondary:hover { background: #666; }
    .btn-sm { padding: 3px 8px; font-size: 12px; }
    input, select, textarea { padding: 6px 8px; border: 1px solid #ccc; font-size: 14px; width: 100%; }
    select { width: 100%; }
    label { display: block; margin: 8px 0 4px; font-weight: bold; font-size: 13px; }
    .form-group { margin-bottom: 12px; }
    .card { border: 1px solid #ddd; padding: 15px; margin: 10px 0; background: #fff; }
    .card h3 { margin-bottom: 10px; }
    h1, h2, h3 { color: #333; }
    a { color: #06c; }
    .badge { display: inline-block; padding: 2px 8px; font-size: 11px; background: #666; color: #fff; }
    .badge-success { background: #090; }
    .badge-danger { background: #c00; }
    .row { display: flex; gap: 15px; flex-wrap: wrap; }
    .col { flex: 1; min-width: 200px; }
    .text-center { text-align: center; }
    .text-muted { color: #888; }
    .mt-10 { margin-top: 10px; }
    .mb-10 { margin-bottom: 10px; }
    .inline { display: inline; }
    hr { margin: 15px 0; border: none; border-top: 1px solid #ddd; }
    footer { text-align: center; padding: 15px; color: #888; font-size: 12px; margin-top: 30px; border-top: 1px solid #ddd; }
  </style>
</head>
<body>

<nav>
  <div>
    <a href="/admin"><b>Canchas Deportivas</b></a>
    <% if (usuario && usuario.rol === 'admin') { %>
      <a href="/admin">Dashboard</a>
      <a href="/admin/tipos">Tipos</a>
      <a href="/admin/canchas">Canchas</a>
      <a href="/admin/horarios">Horarios</a>
      <a href="/admin/reservas">Reservas</a>
      <a href="/admin/resenas">Reseñas</a>
    <% } %>
    <% if (usuario && usuario.rol === 'cliente') { %>
      <a href="/canchas">Canchas</a>
      <a href="/reservas/mis-reservas">Mis Reservas</a>
    <% } %>
  </div>
  <div class="nav-right">
    <% if (usuario) { %>
      <span><%= usuario.nombre %> (<%= usuario.rol %>)</span>
      <a href="/auth/logout">Salir</a>
    <% } else { %>
      <a href="/auth/login">Login</a>
      <a href="/auth/register">Registro</a>
    <% } %>
  </div>
</nav>

<div class="container">
