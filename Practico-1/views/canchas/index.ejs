<%- include('../partials/header') %>

<h2>Canchas Disponibles</h2>

<% if (canchas && canchas.length > 0) { %>
  <table>
    <thead>
      <tr>
        <th>Nombre</th>
        <th>Tipo</th>
        <th>Precio/Hora</th>
        <th>Ver</th>
      </tr>
    </thead>
    <tbody>
      <% canchas.forEach(cancha => { %>
        <tr>
          <td><%= cancha.nombre %></td>
          <td><%= cancha.tipo ? cancha.tipo.nombre : '-' %></td>
          <td>$<%= cancha.precio_por_hora %></td>
          <td><a href="/canchas/<%= cancha.id %>">Ver horarios</a></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } else { %>
  <p class="text-muted">No hay canchas disponibles.</p>
<% } %>

<%- include('../partials/footer') %>
