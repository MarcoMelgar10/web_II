<%- include('../partials/header') %>

<h2><%= cancha.nombre %></h2>
<p>Tipo: <b><%= cancha.tipo ? cancha.tipo.nombre : '-' %></b> | Precio: <b>$<%= cancha.precio_por_hora %>/hora</b></p>

<hr>

<h3>Horarios Disponibles</h3>
<form action="/canchas/<%= cancha.id %>" method="GET" style="margin: 10px 0;">
  <label for="fecha" style="display: inline;">Fecha:</label>
  <input type="date" id="fecha" name="fecha" value="<%= fechaSeleccionada %>" style="width: auto;">
  <button type="submit" class="btn btn-sm">Buscar</button>
</form>

<% if (horarios && horarios.length > 0) { %>
  <table>
    <thead>
      <tr>
        <th>Hora Inicio</th>
        <th>Hora Fin</th>
        <th>Acción</th>
      </tr>
    </thead>
    <tbody>
      <% horarios.forEach(horario => { %>
        <tr>
          <td><%= horario.hora_inicio %></td>
          <td><%= horario.hora_fin %></td>
          <td>
            <% if (usuario && usuario.rol === 'cliente') { %>
              <form action="/reservas" method="POST" class="inline">
                <input type="hidden" name="horario_id" value="<%= horario.id %>">
                <button type="submit" class="btn btn-success btn-sm">Reservar</button>
              </form>
            <% } else if (!usuario) { %>
              <a href="/auth/login" class="btn btn-sm">Login para reservar</a>
            <% } else { %>
              <span class="text-muted">Solo clientes</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } else { %>
  <p class="text-muted">No hay horarios para esta fecha.</p>
<% } %>

<hr>

<h3>Reseñas (<%= resenas.length %>)</h3>
<% if (resenas && resenas.length > 0) { %>
  <% resenas.forEach(resena => { %>
    <div class="card">
      <b><%= resena.usuario ? resena.usuario.nombre : 'Usuario' %></b> - <%= resena.calificacion %>/5
      <% if (resena.comentario) { %>
        <p><%= resena.comentario %></p>
      <% } %>
    </div>
  <% }) %>
<% } else { %>
  <p class="text-muted">Sin reseñas.</p>
<% } %>

<%- include('../partials/footer') %>
