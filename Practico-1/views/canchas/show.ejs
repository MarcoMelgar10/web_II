<%- include('../partials/header') %>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/">Inicio</a></li>
    <li class="breadcrumb-item"><a href="/canchas">Canchas</a></li>
    <li class="breadcrumb-item active"><%= cancha.nombre %></li>
  </ol>
</nav>

<div class="card mb-4">
  <div class="card-body">
    <div class="row">
      <div class="col-md-8">
        <span class="badge bg-secondary"><%= cancha.tipo ? cancha.tipo.nombre : 'Sin tipo' %></span>
        <span class="badge bg-<%= cancha.estado === 'activa' ? 'success' : 'secondary' %>"><%= cancha.estado %></span>
        <h2 class="mt-2"><%= cancha.nombre %></h2>
        <% if (promedioCalificacion) { %>
          <% const promNum = parseFloat(promedioCalificacion); %>
          <p>
            <% for(let i = 1; i <= 5; i++) { %>
              <span class="<%= i <= Math.round(promNum) ? 'star-filled' : 'star-empty' %>">&#9733;</span>
            <% } %>
            <strong><%= promedioCalificacion %></strong>
            <small class="text-muted">(<%= resenas.length %> reseña<%= resenas.length === 1 ? '' : 's' %>)</small>
          </p>
        <% } else { %>
          <p class="text-muted">Sin calificaciones</p>
        <% } %>
      </div>
      <div class="col-md-4 text-md-end">
        <h3 class="text-success">$<%= Number(cancha.precio_por_hora).toLocaleString('es-AR') %></h3>
        <small class="text-muted">por hora</small>
      </div>
    </div>
  </div>
</div>

<div class="card mb-4">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h5 class="mb-0">Horarios Disponibles</h5>
    <form action="/canchas/<%= cancha.id %>" method="GET" class="d-flex align-items-center gap-2">
      <label for="fecha" class="form-label mb-0 small">Fecha:</label>
      <input type="date" class="form-control form-control-sm" id="fecha" name="fecha"
        value="<%= fechaSeleccionada %>"
        min="<%= new Date().toISOString().split('T')[0] %>"
        onchange="this.form.submit()"
        style="width: auto;">
      <button type="submit" class="btn btn-dark btn-sm">Buscar</button>
    </form>
  </div>
  <div class="card-body">
    <p class="text-muted">
      Fecha: <strong><%= new Date(fechaSeleccionada + 'T00:00:00').toLocaleDateString('es-AR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></strong>
    </p>

    <% if (horarios && horarios.length > 0) { %>
      <div class="row">
        <% horarios.forEach(horario => { %>
          <div class="col-sm-6 col-md-3 mb-3">
            <div class="card text-center">
              <div class="card-body py-3">
                <h5><%= horario.hora_inicio %> - <%= horario.hora_fin %></h5>
                <small class="text-success">Disponible</small>
              </div>
              <div class="card-footer p-2">
                <% if (usuario) { %>
                  <% if (usuario.rol === 'cliente') { %>
                    <form action="/reservas" method="POST">
                      <input type="hidden" name="horario_id" value="<%= horario.id %>">
                      <button type="submit" class="btn btn-success btn-sm w-100">Reservar</button>
                    </form>
                  <% } else { %>
                    <button class="btn btn-secondary btn-sm w-100" disabled>Solo clientes</button>
                  <% } %>
                <% } else { %>
                  <a href="/auth/login" class="btn btn-outline-dark btn-sm w-100">Iniciar sesión</a>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-center py-4">
        <p class="text-muted">No hay horarios disponibles para esta fecha.</p>
      </div>
    <% } %>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h5 class="mb-0">Reseñas (<%= resenas.length %>)</h5>
  </div>
  <div class="card-body">
    <% if (resenas && resenas.length > 0) { %>
      <% resenas.forEach(resena => { %>
        <div class="border-bottom pb-3 mb-3">
          <div class="d-flex justify-content-between">
            <div>
              <strong><%= resena.usuario ? resena.usuario.nombre : 'Usuario' %></strong>
              <div>
                <% for(let i = 1; i <= 5; i++) { %>
                  <span class="<%= i <= resena.calificacion ? 'star-filled' : 'star-empty' %>">&#9733;</span>
                <% } %>
                <small class="text-muted">(<%= resena.calificacion %>/5)</small>
              </div>
            </div>
            <small class="text-muted"><%= new Date(resena.createdAt).toLocaleDateString('es-AR') %></small>
          </div>
          <% if (resena.comentario) { %>
            <p class="mt-2 mb-0 text-muted"><%= resena.comentario %></p>
          <% } %>
        </div>
      <% }) %>
    <% } else { %>
      <p class="text-center text-muted">No hay reseñas para esta cancha.</p>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
