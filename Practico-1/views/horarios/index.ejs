<%- include('../partials/header') %>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/admin">Admin</a></li>
    <li class="breadcrumb-item active">Horarios</li>
  </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h3>Gestión de Horarios</h3>
  <a href="/admin/horarios/create" class="btn btn-dark btn-sm">Nuevo Horario</a>
</div>

<div class="card mb-4">
  <div class="card-body py-3">
    <form action="/admin/horarios" method="GET" class="row g-2 align-items-end">
      <div class="col-md-4">
        <label class="form-label small">Cancha</label>
        <select class="form-select form-select-sm" name="cancha_id">
          <option value="">Todas</option>
          <% canchas.forEach(c => { %>
            <option value="<%= c.id %>" <%= filtros.cancha_id == c.id ? 'selected' : '' %>><%= c.nombre %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label small">Fecha</label>
        <input type="date" class="form-control form-control-sm" name="fecha" value="<%= filtros.fecha %>">
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-dark btn-sm w-100">Filtrar</button>
      </div>
      <div class="col-md-2">
        <a href="/admin/horarios" class="btn btn-secondary btn-sm w-100">Limpiar</a>
      </div>
    </form>
  </div>
</div>

<% if (horarios && horarios.length > 0) { %>
  <div class="table-responsive">
    <table class="table table-bordered">
      <thead class="table-dark">
        <tr>
          <th>#</th>
          <th>Cancha</th>
          <th>Tipo</th>
          <th>Fecha</th>
          <th>Hora Inicio</th>
          <th>Hora Fin</th>
          <th>Disponible</th>
          <th class="text-center">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% horarios.forEach((horario, idx) => { %>
          <tr>
            <td><%= idx + 1 %></td>
            <td><%= horario.cancha ? horario.cancha.nombre : 'N/A' %></td>
            <td><%= horario.cancha && horario.cancha.tipo ? horario.cancha.tipo.nombre : 'N/A' %></td>
            <td><%= new Date(horario.fecha + 'T00:00:00').toLocaleDateString('es-AR') %></td>
            <td><%= horario.hora_inicio %></td>
            <td><%= horario.hora_fin %></td>
            <td>
              <% if (horario.disponible) { %>
                <span class="badge bg-success">Sí</span>
              <% } else { %>
                <span class="badge bg-secondary">No</span>
              <% } %>
            </td>
            <td class="text-center">
              <form action="/admin/horarios/<%= horario.id %>?_method=DELETE" method="POST" class="d-inline"
                    onsubmit="return confirm('¿Eliminar este horario?')">
                <input type="hidden" name="_method" value="DELETE">
                <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } else { %>
  <div class="text-center py-5">
    <p class="text-muted">No se encontraron horarios.</p>
    <a href="/admin/horarios/create" class="btn btn-dark">Crear horario</a>
  </div>
<% } %>

<%- include('../partials/footer') %>
