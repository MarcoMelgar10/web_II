<%- include('../../partials/header') %>

<h2>Tipos de Cancha</h2>
<p><a href="/admin/tipos/create" class="btn btn-sm">Nuevo Tipo</a></p>

<% if (tipos && tipos.length > 0) { %>
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Nombre</th>
        <th>Canchas</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% tipos.forEach((tipo, idx) => { %>
        <tr>
          <td><%= idx + 1 %></td>
          <td><%= tipo.nombre %></td>
          <td><%= tipo.canchas ? tipo.canchas.length : 0 %></td>
          <td>
            <a href="/admin/tipos/<%= tipo.id %>/edit" class="btn btn-warning btn-sm">Editar</a>
            <form action="/admin/tipos/<%= tipo.id %>?_method=DELETE" method="POST" class="inline"
                  onsubmit="return confirm('¿Eliminar?')">
              <input type="hidden" name="_method" value="DELETE">
              <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } else { %>
  <p class="text-muted">No hay tipos registrados.</p>
<% } %>

<%- include('../../partials/footer') %>
