<%- include('../../partials/header') %>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/admin">Admin</a></li>
    <li class="breadcrumb-item active">Tipos de Cancha</li>
  </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h3>Tipos de Cancha</h3>
  <a href="/admin/tipos/create" class="btn btn-dark btn-sm">Nuevo Tipo</a>
</div>

<% if (tipos && tipos.length > 0) { %>
  <div class="table-responsive">
    <table class="table table-bordered">
      <thead class="table-dark">
        <tr>
          <th>#</th>
          <th>Nombre</th>
          <th>Canchas asociadas</th>
          <th>Creado</th>
          <th class="text-center">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% tipos.forEach((tipo, idx) => { %>
          <tr>
            <td><%= idx + 1 %></td>
            <td><%= tipo.nombre %></td>
            <td><%= tipo.canchas ? tipo.canchas.length : 0 %></td>
            <td><%= new Date(tipo.createdAt).toLocaleDateString('es-AR') %></td>
            <td class="text-center">
              <form action="/admin/tipos/<%= tipo.id %>?_method=DELETE" method="POST" class="d-inline"
                    onsubmit="return confirm('¿Eliminar el tipo \"<%= tipo.nombre %>\"?')">
                <input type="hidden" name="_method" value="DELETE">
                <button type="submit" class="btn btn-sm btn-danger"
                        <%= tipo.canchas && tipo.canchas.length > 0 ? 'disabled' : '' %>>Eliminar</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } else { %>
  <div class="text-center py-5">
    <p class="text-muted">No hay tipos de cancha registrados.</p>
    <a href="/admin/tipos/create" class="btn btn-dark">Crear primer tipo</a>
  </div>
<% } %>

<%- include('../../partials/footer') %>
