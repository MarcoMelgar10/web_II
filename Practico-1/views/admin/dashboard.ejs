<%- include('../partials/header') %>

<h3>Panel de Administración</h3>
<p class="text-muted">Bienvenido, <strong><%= usuario.nombre %></strong></p>

<div class="row mb-4">
  <div class="col-md-3 mb-3">
    <div class="card text-center">
      <div class="card-body">
        <h2><%= stats.totalCanchas %></h2>
        <p class="mb-0">Canchas</p>
      </div>
    </div>
  </div>
  <div class="col-md-3 mb-3">
    <div class="card text-center">
      <div class="card-body">
        <h2><%= stats.totalUsuarios %></h2>
        <p class="mb-0">Clientes</p>
      </div>
    </div>
  </div>
  <div class="col-md-3 mb-3">
    <div class="card text-center">
      <div class="card-body">
        <h2><%= stats.totalReservas %></h2>
        <p class="mb-0">Reservas</p>
      </div>
    </div>
  </div>
  <div class="col-md-3 mb-3">
    <div class="card text-center">
      <div class="card-body">
        <h2><%= stats.reservasConfirmadas %></h2>
        <p class="mb-0">Confirmadas</p>
      </div>
    </div>
  </div>
</div>

<h5>Acciones Rápidas</h5>
<div class="row">
  <div class="col-md-3 mb-3">
    <a href="/admin/canchas" class="btn btn-outline-dark w-100 py-3">Gestionar Canchas</a>
  </div>
  <div class="col-md-3 mb-3">
    <a href="/admin/horarios/create" class="btn btn-outline-dark w-100 py-3">Crear Horario</a>
  </div>
  <div class="col-md-3 mb-3">
    <a href="/admin/reservas" class="btn btn-outline-dark w-100 py-3">Ver Reservas</a>
  </div>
  <div class="col-md-3 mb-3">
    <a href="/admin/tipos" class="btn btn-outline-dark w-100 py-3">Tipos de Cancha</a>
  </div>
</div>

<%- include('../partials/footer') %>
