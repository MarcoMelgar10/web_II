<%- include('../partials/header') %>

<h2>Panel de Administración</h2>
<p>Bienvenido, <b><%= usuario.nombre %></b></p>

<div class="row">
  <div class="col">
    <div class="card text-center">
      <h2><%= stats.totalCanchas %></h2>
      <p>Canchas</p>
    </div>
  </div>
  <div class="col">
    <div class="card text-center">
      <h2><%= stats.totalUsuarios %></h2>
      <p>Clientes</p>
    </div>
  </div>
  <div class="col">
    <div class="card text-center">
      <h2><%= stats.totalReservas %></h2>
      <p>Reservas</p>
    </div>
  </div>
  <div class="col">
    <div class="card text-center">
      <h2><%= stats.reservasConfirmadas %></h2>
      <p>Confirmadas</p>
    </div>
  </div>
</div>

<h3 class="mt-10">Acciones</h3>
<p>
  <a href="/admin/canchas" class="btn">Canchas</a>
  <a href="/admin/horarios" class="btn">Horarios</a>
  <a href="/admin/reservas" class="btn">Reservas</a>
  <a href="/admin/tipos" class="btn">Tipos</a>
</p>

<%- include('../partials/footer') %>
