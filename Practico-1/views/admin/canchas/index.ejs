<%- include('../../partials/header') %>

<h2>Canchas</h2>
<p><a href="/admin/canchas/create" class="btn btn-sm">Nueva Cancha</a></p>

<% if (canchas && canchas.length > 0) { %>
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Nombre</th>
        <th>Tipo</th>
        <th>Precio/Hora</th>
        <th>Estado</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% canchas.forEach((cancha, idx) => { %>
        <tr>
          <td><%= idx + 1 %></td>
          <td><%= cancha.nombre %></td>
          <td><%= cancha.tipo ? cancha.tipo.nombre : '-' %></td>
          <td>$<%= cancha.precio_por_hora %></td>
          <td><%= cancha.estado %></td>
          <td>
            <a href="/admin/canchas/<%= cancha.id %>/edit" class="btn btn-warning btn-sm">Editar</a>
            <form action="/admin/canchas/<%= cancha.id %>?_method=DELETE" method="POST" class="inline"
                  onsubmit="return confirm('¿Eliminar?')">
              <input type="hidden" name="_method" value="DELETE">
              <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } else { %>
  <p class="text-muted">No hay canchas registradas.</p>
<% } %>

<%- include('../../partials/footer') %>
