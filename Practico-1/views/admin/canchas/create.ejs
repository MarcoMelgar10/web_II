<%- include('../../partials/header') %>

<h2>Nueva Cancha</h2>

<div class="card" style="max-width: 450px;">
  <form action="/admin/canchas" method="POST">
    <div class="form-group">
      <label for="nombre">Nombre</label>
      <input type="text" id="nombre" name="nombre" required>
    </div>
    <div class="form-group">
      <label for="tipo_id">Tipo de cancha</label>
      <select id="tipo_id" name="tipo_id" required>
        <option value="">Seleccionar</option>
        <% tipos.forEach(tipo => { %>
          <option value="<%= tipo.id %>"><%= tipo.nombre %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label for="precio_por_hora">Precio por hora ($)</label>
      <input type="number" id="precio_por_hora" name="precio_por_hora" min="0" step="0.01" required>
    </div>
    <div class="form-group">
      <label for="estado">Estado</label>
      <select id="estado" name="estado">
        <option value="activa">Activa</option>
        <option value="inactiva">Inactiva</option>
      </select>
    </div>
    <button type="submit" class="btn">Crear</button>
    <a href="/admin/canchas" class="btn btn-secondary">Cancelar</a>
  </form>
</div>

<%- include('../../partials/footer') %>
