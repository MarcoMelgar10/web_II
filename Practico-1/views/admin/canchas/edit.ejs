<%- include('../../partials/header') %>

<h2>Editar Cancha</h2>

<div class="card" style="max-width: 450px;">
  <form action="/admin/canchas/<%= cancha.id %>?_method=PUT" method="POST">
    <input type="hidden" name="_method" value="PUT">
    <div class="form-group">
      <label for="nombre">Nombre</label>
      <input type="text" id="nombre" name="nombre" value="<%= cancha.nombre %>" required>
    </div>
    <div class="form-group">
      <label for="tipo_id">Tipo de cancha</label>
      <select id="tipo_id" name="tipo_id" required>
        <option value="">Seleccionar</option>
        <% tipos.forEach(tipo => { %>
          <option value="<%= tipo.id %>" <%= cancha.tipo_id == tipo.id ? 'selected' : '' %>><%= tipo.nombre %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label for="precio_por_hora">Precio por hora ($)</label>
      <input type="number" id="precio_por_hora" name="precio_por_hora" min="0" step="0.01" value="<%= cancha.precio_por_hora %>" required>
    </div>
    <div class="form-group">
      <label for="estado">Estado</label>
      <select id="estado" name="estado">
        <option value="activa" <%= cancha.estado === 'activa' ? 'selected' : '' %>>Activa</option>
        <option value="inactiva" <%= cancha.estado === 'inactiva' ? 'selected' : '' %>>Inactiva</option>
      </select>
    </div>
    <button type="submit" class="btn">Guardar</button>
    <a href="/admin/canchas" class="btn btn-secondary">Cancelar</a>
  </form>
</div>

<%- include('../../partials/footer') %>
