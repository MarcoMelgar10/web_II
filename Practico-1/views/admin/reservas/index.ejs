<%- include('../../partials/header') %>

<h2>Reservas</h2>
<p>Total: <b><%= reservas.length %></b></p>

<% if (reservas && reservas.length > 0) { %>
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Usuario</th>
        <th>Cancha</th>
        <th>Fecha</th>
        <th>Horario</th>
        <th>Estado</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% reservas.forEach((reserva, idx) => { %>
        <tr>
          <td><%= idx + 1 %></td>
          <td>
            <%= reserva.usuario ? reserva.usuario.nombre : '-' %>
            <% if (reserva.usuario) { %>
              <br><small><%= reserva.usuario.email %></small>
            <% } %>
          </td>
          <td>
            <% if (reserva.horario && reserva.horario.cancha) { %>
              <%= reserva.horario.cancha.nombre %>
            <% } else { %>
              -
            <% } %>
          </td>
          <td><%= reserva.horario ? reserva.horario.fecha : '-' %></td>
          <td>
            <% if (reserva.horario) { %>
              <%= reserva.horario.hora_inicio %> - <%= reserva.horario.hora_fin %>
            <% } %>
          </td>
          <td>
            <span class="badge <%= reserva.estado === 'confirmada' ? 'badge-success' : '' %>">
              <%= reserva.estado %>
            </span>
          </td>
          <td>
            <form action="/admin/reservas/<%= reserva.id %>/estado?_method=PUT" method="POST" class="inline">
              <input type="hidden" name="_method" value="PUT">
              <% if (reserva.estado === 'confirmada') { %>
                <input type="hidden" name="estado" value="cancelada">
                <button type="submit" class="btn btn-danger btn-sm"
                        onclick="return confirm('¿Cancelar?')">Cancelar</button>
              <% } else { %>
                <input type="hidden" name="estado" value="confirmada">
                <button type="submit" class="btn btn-success btn-sm"
                        onclick="return confirm('¿Confirmar?')">Confirmar</button>
              <% } %>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } else { %>
  <p class="text-muted">No hay reservas.</p>
<% } %>

<%- include('../../partials/footer') %>
