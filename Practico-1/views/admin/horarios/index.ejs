<%- include('../../partials/header') %>

<h2>Horarios</h2>
<p><a href="/admin/horarios/create" class="btn btn-sm">Nuevo Horario</a></p>

<div class="card mb-10">
  <form action="/admin/horarios" method="GET" class="row">
    <div class="col">
      <label>Cancha</label>
      <select name="cancha_id">
        <option value="">Todas</option>
        <% canchas.forEach(c => { %>
          <option value="<%= c.id %>" <%= filtros.cancha_id == c.id ? 'selected' : '' %>><%= c.nombre %></option>
        <% }) %>
      </select>
    </div>
    <div class="col">
      <label>Fecha</label>
      <input type="date" name="fecha" value="<%= filtros.fecha %>">
    </div>
    <div class="col" style="padding-top: 25px;">
      <button type="submit" class="btn">Filtrar</button>
      <a href="/admin/horarios" class="btn btn-secondary">Limpiar</a>
    </div>
  </form>
</div>

<% if (horarios && horarios.length > 0) { %>
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Cancha</th>
        <th>Tipo</th>
        <th>Fecha</th>
        <th>Inicio</th>
        <th>Fin</th>
        <th>Disponible</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% horarios.forEach((horario, idx) => { %>
        <tr>
          <td><%= idx + 1 %></td>
          <td><%= horario.cancha ? horario.cancha.nombre : '-' %></td>
          <td><%= horario.cancha && horario.cancha.tipo ? horario.cancha.tipo.nombre : '-' %></td>
          <td><%= horario.fecha %></td>
          <td><%= horario.hora_inicio %></td>
          <td><%= horario.hora_fin %></td>
          <td><%= horario.disponible ? 'Sí' : 'No' %></td>
          <td>
            <form action="/admin/horarios/<%= horario.id %>?_method=DELETE" method="POST" class="inline"
                  onsubmit="return confirm('¿Eliminar?')">
              <input type="hidden" name="_method" value="DELETE">
              <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } else { %>
  <p class="text-muted">No hay horarios.</p>
<% } %>

<%- include('../../partials/footer') %>
