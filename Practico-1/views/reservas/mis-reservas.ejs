<%- include('../partials/header') %>

<h2>Mis Reservas</h2>
<p><a href="/canchas" class="btn btn-sm">Nueva Reserva</a></p>

<% if (reservas && reservas.length > 0) { %>
  <table>
    <thead>
      <tr>
        <th>Cancha</th>
        <th>Fecha</th>
        <th>Horario</th>
        <th>Estado</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% reservas.forEach(reserva => { %>
        <tr>
          <td><%= reserva.horario && reserva.horario.cancha ? reserva.horario.cancha.nombre : '-' %></td>
          <td><%= reserva.horario ? reserva.horario.fecha : '-' %></td>
          <td>
            <% if (reserva.horario) { %>
              <%= reserva.horario.hora_inicio %> - <%= reserva.horario.hora_fin %>
            <% } %>
          </td>
          <td><%= reserva.estado %></td>
          <td>
            <% if (reserva.estado === 'confirmada') { %>
              <form action="/reservas/<%= reserva.id %>/cancelar" method="POST" class="inline"
                    onsubmit="return confirm('¿Cancelar?')">
                <button type="submit" class="btn btn-danger btn-sm">Cancelar</button>
              </form>
            <% } %>
            <% if (reserva.estado === 'confirmada' && reserva.horario && reserva.horario.cancha) { %>
              <a href="/resenas/create/<%= reserva.id %>" class="btn btn-warning btn-sm">Reseña</a>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } else { %>
  <p class="text-muted">No tenés reservas. <a href="/canchas">Ver canchas</a></p>
<% } %>

<%- include('../partials/footer') %>
